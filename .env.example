# Base URL of the GuitarCollection API (no trailing slash).
# Example: https://abc123.execute-api.eu-west-1.amazonaws.com/Prod
VITE_GUITARS_API_BASE_URL=

# Bearer token baked into the build at build time. Optional.
# WARNING: any value provided here is shipped in the static bundle and is
# therefore publicly visible. For shared deploys prefer leaving this blank and
# entering a token at runtime on the /settings page.
VITE_GUITARS_BEARER_TOKEN=
