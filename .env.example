# Base URL of the GuitarCollection API (no trailing slash).
# Example: https://guitars.brouwers.club
VITE_GUITARS_API_BASE_URL=

# Bearer token baked into the build at build time. Optional.
# Used only when Cognito env vars below are not set (local development).
VITE_GUITARS_BEARER_TOKEN=

# Amazon Cognito (production auth). When all three are set, the app uses
# registration and sign-in pages instead of manual token entry.
VITE_COGNITO_REGION=eu-central-1
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
