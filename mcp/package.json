{
  "name": "@wbits/guitars-mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server for the GuitarCollection API",
  "bin": {
    "guitars-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\" --external:@modelcontextprotocol/sdk",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.12",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
